    <org.eventb.core.invariant name="5" org.eventb.core.label="inv5" org.eventb.core.predicate="∀p,q· p ∈ Node ∧ q ∈ Node ⇒ rcvd(p↦q) ≤ sent(p↦q)"/>
    <org.eventb.core.invariant name="6" org.eventb.core.label="inv6" org.eventb.core.predicate="termdetect = TRUE ⇒ active = ∅ ∧ sent = rcvd"/>
